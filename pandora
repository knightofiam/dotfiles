#!/usr/bin/env zsh

PANDORA_FIFO="${HOME}/.config/pianobar/ctl"

check_dependencies() {
  local missing=()

  command -v pianobar >/dev/null 2>&1 || missing+=("pianobar")
  command -v screen >/dev/null 2>&1 || missing+=("screen")
  command -v op >/dev/null 2>&1 || missing+=("op (1Password CLI)")

  if (( ${#missing[@]} > 0 )); then
    printf "Error: Missing required dependencies:\n"
    for dep in "${missing[@]}"; do
      printf "  - %s\n" "$dep"
    done
    printf "\nInstall with:\n"
    [[ " ${missing[*]} " =~ " pianobar " ]] && printf "  brew install pianobar\n"
    [[ " ${missing[*]} " =~ " op (1Password CLI) " ]] && printf "  brew install --cask 1password-cli\n"
    return 1
  fi
  return 0
}

pandora() {
  [[ $1 == "quit" ]] && { quit_pandora; return; }

  # Check dependencies before doing anything
  check_dependencies || return 1

  is_pandora_running && { resume_pandora; return; }

  # Fetch password from 1Password (in the foreground where Touch ID works).
  # If Touch ID times out, press any key to retry.
  local pw=""
  until pw=$(op item get 4wrr4xvuwzfgpayczrmsnefihy --fields password --reveal 2>/dev/null) && [[ -n "$pw" ]]; do
    read -sk1 "?Touch ID timed out. Press any key to retry (Ctrl-C to cancel)..."
    printf "\n"
  done

  # Cache the password so pianobar can read it without another Touch ID prompt
  printf "%s" "$pw" > /tmp/.pianobar-pw
  chmod 600 /tmp/.pianobar-pw
  unset pw

  start_pandora || { rm -f /tmp/.pianobar-pw; return 1; }
  resume_pandora
}

start_pandora() {
  remove_pandora_fifo

  # Create FIFO
  if ! mkfifo "${PANDORA_FIFO}" 2>/dev/null; then
    printf "Error: Failed to create control FIFO at %s\n" "${PANDORA_FIFO}"
    return 1
  fi

  # Start pianobar in screen session
  if ! screen -dmS pandora zsh -c pianobar; then
    printf "Error: Failed to start pianobar in screen session\n"
    remove_pandora_fifo
    return 1
  fi

  # Give pianobar a moment to start and authenticate
  sleep 3

  # Clean up cached password
  rm -f /tmp/.pianobar-pw
}

send_to_pandora() {
  if [[ ! -p "${PANDORA_FIFO}" ]]; then
    printf "Error: Pandora control FIFO not found. Is pianobar running?\n"
    return 1
  fi

  # Send playback control command
  echo "$1" > "${PANDORA_FIFO}"
}

is_pandora_running() {
  screen -list | grep -q "pandora"
}

resume_pandora() {
  screen -rd pandora &> /dev/null
}

quit_pandora() {
  is_pandora_running && echo "q" > "${PANDORA_FIFO}"
  is_pandora_running && screen -X -S pandora quit
  is_pandora_running && printf "Error: Failed to q" || printf "Q"
  printf "uit Pandora.\n"
  remove_pandora_fifo
}

remove_pandora_fifo() {
  rm "${PANDORA_FIFO}" &> /dev/null
}
